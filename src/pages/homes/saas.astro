---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';


import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Pricing from '~/components/widgets/Pricing.astro';
const metadata = {
  title: 'Bitcoin Staking',
};
---

<Layout metadata={metadata}>
  <script type='text/javascript' src='https://platform-api.sharethis.com/js/sharethis.js#property=69ea0705c6df4150e2d9e264&product=sop' async='async'></script>
  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'EXCHANGE',
          href: '/home/exchange',
        },
        {
          variant: 'primary',
          text: 'Stake BTC',
          href: '/stake/BTC',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline=""
    actions={[
      { variant: 'primary', target: '', text: 'Stake.BTC', href: '/stake/BTC' },
      { text: 'Exchange', href: '/home/exchange' },
      { text: 'Bridge.BTC', href: 'https://symbiosis.finance/bridge-btc/eth' },
      { text: 'BUY.Wallet', href: '/home/BUY' },
    ]}
    image={{
      src: 'https://imglink.cc/cdn/cQTAni2-Je.png',
      alt: 'Bitcoin',
    }}
  >
    <Fragment slot="title">
    <!-- TradingView Widget BEGIN -->
<div class="tradingview-widget-container">
  <div class="tradingview-widget-container__widget"></div>
  <div class="tradingview-widget-copyright"><a href="https://www.tradingview.com/symbols/BTCUSD/?exchange=COINBASE" rel="noopener nofollow" target="_blank"><span class="blue-text"></span></a><span class="trademark"></span></div>
  <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-symbol-overview.js" async>
  {
  "lineWidth": 2,
  "lineType": 0,
  "chartType": "area",
  "fontColor": "rgb(106, 109, 120)",
  "gridLineColor": "rgba(255, 255, 255, 0.06)",
  "volumeUpColor": "rgba(34, 171, 148, 0.5)",
  "volumeDownColor": "rgba(247, 82, 95, 0.5)",
  "backgroundColor": "rgba(4, 4, 34, 1)",
  "widgetFontColor": "rgba(255, 255, 255, 1)",
  "upColor": "#22ab94",
  "downColor": "#f7525f",
  "borderUpColor": "#22ab94",
  "borderDownColor": "#f7525f",
  "wickUpColor": "#22ab94",
  "wickDownColor": "#f7525f",
  "colorTheme": "dark",
  "isTransparent": true,
  "locale": "en",
  "chartOnly": false,
  "scalePosition": "right",
  "scaleMode": "Normal",
  "fontFamily": "-apple-system, BlinkMacSystemFont, Trebuchet MS, Roboto, Ubuntu, sans-serif",
  "valuesTracking": "1",
  "changeMode": "price-and-percent",
  "symbols": [
    [
      "COINBASE:BTCUSD|1M"
    ]
  ],
  "dateRanges": [
    "1d|1",
    "1m|30",
    "3m|60",
    "12m|1D",
    "60m|1W",
    "all|1M"
  ],
  "fontSize": "10",
  "headerFontSize": "medium",
  "autosize": false,
  "width": "100%",
  "height": "500",
  "noTimeScale": false,
  "hideDateRanges": false,
  "hideMarketStatus": false,
  "hideSymbolLogo": false
}
  </script>
</div>
<!-- TradingView Widget END -->
    </Fragment>
  </Hero2>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    title="Learn more about staking"
    subtitle="Choose Sukra as your node operator and experience unparalleled professionalism, security, and support."
    columns={2}
    items={[
      {
        title: 'What is Staking?',
        description:
          'Staking allows you to lock your assets on a blockchain to support the network security. By delegating to operators like Stakely, your staked assets help verify transactions and maintain the blockchain active. In return, you earn staking rewards.',
        icon: 'tabler:layers-union',
      },
      {
        title: 'How Does Staking Work?',
        description: `When you stake your assets, you are essentially "delegating" them to a validator or node operator like Stakely. These validators verify transactions and add them to the blockchain. In return for providing this service, they earn rewards, which are shared with the delegators.`,
        icon: 'tabler:artboard',
      },
      {
        title: 'What is Validator?',
        description:
          'Validators play a pivotal role in Proof-of-Stake networks, validating transactions and upholding network integrity. Choosing us means trusting a verified staking provider with a proven track record of reliability and professionalism.',
        icon: 'tabler:writing',
      },
      {
        title: 'Where do Staking Rewards Come From?',
        description:
          'Staking rewards are typically generated from two sources: 1) Transaction fees: network users pay fees for transactions, which are distributed as rewards. 2) Inflation: some blockchain networks create new tokens to distribute as staking rewards. This incentivizes participation and ensures network security.',
        icon: 'tabler:layers-union',
      },
      {
        title: 'What the risks associated with staking?',
        description: `WWhile staking can be highly rewarding, it does have risks including network failures, system hacks, and market volatility. To mitigate potential slashing risks, Stakely offers a comprehensive Staking Insurance Program to protect your investments and provide peace of mind.`,
        icon: 'tabler:artboard',
      },
      {
        title: 'How can i start staking with ponco?',
        description:
          'Getting started is easy! Our platform guides you through the staking process step by step, helping you make informed decisions with educational tutorials and blog articles. You can also reach out to our support team for personalized assistance..',
        icon: 'tabler:writing',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    title="Deep dive on BTC staking"
    subtitle="By staking your Bitcoin with ponco, you can put your assets to work, receive rewards, and actively contribute to the growth and security of the Bitcoin ecosystem."
    isReversed
    items={[
      {
        title: 'Description:',
        description:
          'Since Bitcoin operates on a PoW mechanism rather than PoS, innovative mechanisms, similar to Ethereums Eigenlayer restaking, enable Bitcoin to participate indirectly in the security of other chains.',
      },
      {
        title: 'Benefits:',
        description: `At Sukra, we've handpicked the most promising projects and are working on integrations with leading custodians to support our institutional customers.`,
      },
    ]}
    image={{
      src: 'https://image2url.com/r2/bucket3/images/1775956175369-988e71e9-6711-44aa-ab04-05fe0ad49e45.png',
      alt: 'Startup Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Optimize rewards opportunities <br /><span class="text-2xl">Increase Bitcoin’s utility</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <script>
  (function(){var w=window;if(w.ChannelIO){return w.console.error("ChannelIO script included twice.");}var ch=function(){ch.c(arguments);};ch.q=[];ch.c=function(args){ch.q.push(args);};w.ChannelIO=ch;function l(){if(w.ChannelIOInitialized){return;}w.ChannelIOInitialized=true;var s=document.createElement("script");s.type="text/javascript";s.async=true;s.src="https://cdn.channel.io/plugin/ch-plugin-web.js";var x=document.getElementsByTagName("script")[0];if(x.parentNode){x.parentNode.insertBefore(s,x);}}if(document.readyState==="complete"){l();}else{w.addEventListener("DOMContentLoaded",l);w.addEventListener("load",l);}})();

  ChannelIO('boot', {
    "pluginKey": "4299e8f0-6290-4f10-b4f7-61071f989b54"
  });
</script>
</Layout>
